{
    "compilerOptions": {
      "target": "ESNext",
      "module": "CommonJS",
      "moduleResolution": "Node10",
      "ignoreDeprecations": "6.0",
      "outDir": "dist",
      "baseUrl": ".",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "paths": {
        "@/*": ["src/*"]
      }
    },
    "include": ["src", "app.ts"],
    "exclude": ["node_modules", "dist"]
  }